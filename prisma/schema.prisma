generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── USER ───────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  avatarUrl     String?
  passwordHash  String?
  isSuspended   Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  memberships         WorkspaceMember[]
  apiKeys             ApiKey[]
  passwordResetTokens PasswordResetToken[]
  mfaSetup            MfaSetup?
}

// ─── NEXTAUTH TABLES ─────────────────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  userAgent    String?
  ipAddress    String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── API KEYS ────────────────────────────────────────────
model ApiKey {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String
  name        String
  keyHash     String    @unique
  keyPrefix   String
  scopes      String[]
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── PASSWORD RESET ──────────────────────────────────────
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── MFA ─────────────────────────────────────────────────
model MfaSetup {
  id          String   @id @default(cuid())
  userId      String   @unique
  secret      String
  backupCodes String[]
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── WORKSPACE (TENANT) ──────────────────────────────────
model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logoUrl   String?
  website   String?
  industry  String?
  timezone  String   @default("America/New_York")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  subscriptionStatus   SubscriptionStatus @default(TRIALING)
  trialEndsAt          DateTime?
  currentPeriodEnd     DateTime?
  plan                 Plan               @default(FREE)

  members       WorkspaceMember[]
  invites       WorkspaceInvite[]
  auditLogs     AuditLog[]
  apiKeys       ApiKey[]
  customers     Customer[]
  invoices      Invoice[]
  products      Product[]
  expenses      Expense[]
  contacts      Contact[]
  deals         Deal[]
  emailCampaigns EmailCampaign[]
  smsCampaigns  SmsCampaign[]
  tickets       Ticket[]
  employees     Employee[]
  documents     Document[]
  storageFiles  StorageFile[]
  analyticsEvents AnalyticsEvent[]
  webhooks      WebhookEndpoint[]
  automations   Automation[]
  services      Service[]
  appointments  Appointment[]
  forms         FormBuilder[]
  clientPortalUsers ClientPortalUser[]
  chartAccounts  ChartAccount[]
  journalEntries JournalEntry[]
  conversations  Conversation[]
  // Communication settings (workspace-level override)
  twilioAccountSid  String?
  twilioAuthToken   String?
  twilioFromNumber  String?
  resendApiKey      String?
  fromEmail         String?
  fromName          String?
  // Twilio sub-account (platform-managed — one per workspace)
  twilioSubAccountSid   String?
  twilioSubAccountToken String?
  twilioPhoneNumber     String?
  twilioPhoneNumberSid  String?
  // SMS usage tracking
  smsUsageThisMonth Int      @default(0)
  smsUsageResetAt   DateTime?
  smsMonthlyLimit   Int      @default(100)
  // Missed call text-back
  missedCallTextBack Boolean @default(false)
  missedCallMessage  String?
  // AI auto-reply to inbound SMS
  aiAutoReply        Boolean @default(false)
  aiAutoReplyPrompt  String?

  emailSequences     EmailSequence[]
  sequenceEnrollments SequenceEnrollment[]
  proposals          Proposal[]
  landingPages       LandingPage[]
  chatWidget         ChatWidget?
  socialPosts        SocialPost[]
  projects           Project[]
  integrations       WorkspaceIntegration[]

  // Agency / White-label
  isAgency           Boolean  @default(false)
  wlBrandName        String?
  wlLogoUrl          String?
  wlPrimaryColor     String?
  wlSupportEmail     String?
  wlCustomDomain     String?
  wlHideAttribution  Boolean  @default(false)

  // Agency owns these client workspaces
  agencyClients      AgencyClient[] @relation("AgencyWorkspace")
  // This workspace is managed by an agency
  agencyOf           AgencyClient[] @relation("ClientWorkspace")
}

model AgencyClient {
  id               String    @id @default(cuid())
  agencyWorkspaceId String
  clientWorkspaceId String
  createdAt        DateTime  @default(now())

  agencyWorkspace  Workspace @relation("AgencyWorkspace", fields: [agencyWorkspaceId], references: [id], onDelete: Cascade)
  clientWorkspace  Workspace @relation("ClientWorkspace", fields: [clientWorkspaceId], references: [id], onDelete: Cascade)

  @@unique([agencyWorkspaceId, clientWorkspaceId])
}

model WorkspaceMember {
  id          String     @id @default(cuid())
  workspaceId String
  userId      String
  role        MemberRole @default(MEMBER)
  joinedAt    DateTime   @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

model WorkspaceInvite {
  id          String     @id @default(cuid())
  workspaceId String
  email       String
  role        MemberRole @default(MEMBER)
  token       String     @unique @default(cuid())
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime   @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, email])
}

// ─── AUDIT LOG ───────────────────────────────────────────
model AuditLog {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String?
  action      String
  metadata    Json?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// ─── PAYMENTS & FINANCE ──────────────────────────────────
model Customer {
  id               String    @id @default(cuid())
  workspaceId      String
  name             String
  email            String
  phone            String?
  company          String?
  address          String?
  city             String?
  state            String?
  zip              String?
  country          String    @default("US")
  stripeCustomerId String?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invoices  Invoice[]
}

model Invoice {
  id          String    @id @default(cuid())
  workspaceId String
  customerId  String?
  number      String
  status      InvoiceStatus @default(DRAFT)
  issueDate   DateTime  @default(now())
  dueDate     DateTime
  subtotal    Float     @default(0)
  taxRate     Float     @default(0)
  taxAmount   Float     @default(0)
  total       Float     @default(0)
  notes       String?
  paidAt      DateTime?
  sentAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customer  Customer?        @relation(fields: [customerId], references: [id])
  lineItems InvoiceLineItem[]

  @@unique([workspaceId, number])
}

model InvoiceLineItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Float   @default(1)
  unitPrice   Float
  total       Float

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Product {
  id              String   @id @default(cuid())
  workspaceId     String
  name            String
  description     String?
  price           Float
  currency        String   @default("USD")
  type            String   @default("ONE_TIME")
  interval        String?
  stripeProductId String?
  stripePriceId   String?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Expense {
  id          String   @id @default(cuid())
  workspaceId String
  description String
  amount      Float
  currency    String   @default("USD")
  category    String
  date        DateTime
  vendor      String?
  notes       String?
  receiptUrl  String?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// ─── CRM ─────────────────────────────────────────────────
model Contact {
  id          String   @id @default(cuid())
  workspaceId String
  firstName   String
  lastName    String?
  email       String?
  phone       String?
  company     String?
  title       String?
  status      String   @default("LEAD")
  source      String?
  tags        String[]
  notes       String?
  leadScore   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace           Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  deals               Deal[]
  conversations       Conversation[]
  contactNotes        ContactNote[]
  sequenceEnrollments SequenceEnrollment[]
  proposals           Proposal[]
  projects            Project[]
}

model ContactNote {
  id          String   @id @default(cuid())
  contactId   String
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  body        String
  createdAt   DateTime @default(now())
}

model Deal {
  id          String   @id @default(cuid())
  workspaceId String
  contactId   String?
  title       String
  value       Float    @default(0)
  currency    String   @default("USD")
  stage       String   @default("LEAD")
  probability Int      @default(0)
  closeDate   DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contact   Contact?  @relation(fields: [contactId], references: [id])
}

// ─── EMAIL CAMPAIGNS ─────────────────────────────────────
model EmailCampaign {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  subject     String
  fromName    String
  fromEmail   String
  htmlBody    String
  status      String   @default("DRAFT")
  sentAt      DateTime?
  recipientCount Int   @default(0)
  openCount   Int      @default(0)
  clickCount  Int      @default(0)
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// ─── SMS CAMPAIGNS ───────────────────────────────────────
model SmsCampaign {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  message     String
  status      String   @default("DRAFT")
  sentAt      DateTime?
  recipientCount Int   @default(0)
  deliveredCount Int   @default(0)
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// ─── SUPPORT / HELPDESK ──────────────────────────────────
model Ticket {
  id          String   @id @default(cuid())
  workspaceId String
  subject     String
  description String
  status      String   @default("OPEN")
  priority    String   @default("NORMAL")
  fromEmail   String
  fromName    String?
  assigneeId  String?
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// ─── HR ──────────────────────────────────────────────────
model Employee {
  id          String   @id @default(cuid())
  workspaceId String
  firstName   String
  lastName    String
  email       String
  phone       String?
  title       String?
  department  String?
  salary      Float?
  currency    String   @default("USD")
  startDate   DateTime
  endDate     DateTime?
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// ─── DOCUMENTS ───────────────────────────────────────────
model Document {
  id          String   @id @default(cuid())
  workspaceId String
  title       String
  content     String   @default("")
  emoji       String?
  parentId    String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// ─── STORAGE ─────────────────────────────────────────────
model StorageFile {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  key         String   @unique
  size        Int
  mimeType    String
  url         String
  folder      String?
  uploadedById String?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// ─── ANALYTICS ───────────────────────────────────────────
model AnalyticsEvent {
  id          String   @id @default(cuid())
  workspaceId String
  event       String
  properties  Json?
  userId      String?
  sessionId   String?
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// ─── WEBHOOKS ────────────────────────────────────────────
model WebhookEndpoint {
  id          String   @id @default(cuid())
  workspaceId String
  url         String
  events      String[]
  secret      String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  workspace     Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  deliveries    WebhookDelivery[]
}

model WebhookDelivery {
  id         String   @id @default(cuid())
  endpointId String
  event      String
  payload    Json
  statusCode Int?
  success    Boolean  @default(false)
  createdAt  DateTime @default(now())

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
}

// ─── AUTOMATIONS ─────────────────────────────────────────
model Automation {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  trigger     Json
  actions     Json
  active      Boolean  @default(true)
  lastRunAt   DateTime?
  runCount    Int      @default(0)
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// ─── BOOKING ─────────────────────────────────────────────
model Service {
  id             String   @id @default(cuid())
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  duration       Int
  price          Float    @default(0)
  color          String   @default("#6366F1")
  active         Boolean  @default(true)
  // Meeting type: in_person | phone | zoom | google_meet | custom
  meetingType    String   @default("in_person")
  meetingLink    String?  // Zoom/Meet link for this service
  // Availability
  availableDays  String[] @default(["MON","TUE","WED","THU","FRI"])
  startTime      String   @default("09:00")
  endTime        String   @default("17:00")
  appointments   Appointment[]
  createdAt      DateTime @default(now())
}

model Appointment {
  id           String   @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  serviceId    String
  service      Service  @relation(fields: [serviceId], references: [id])
  clientName   String
  clientEmail  String
  clientPhone  String?
  date         DateTime
  status       AppointmentStatus @default(PENDING)
  notes        String?
  meetingLink  String?  // Resolved meeting link for this specific appointment
  createdAt    DateTime @default(now())
}

// ─── FORMS ───────────────────────────────────────────────
model FormBuilder {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  fields      Json
  submissions FormSubmission[]
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model FormSubmission {
  id        String      @id @default(cuid())
  formId    String
  form      FormBuilder @relation(fields: [formId], references: [id], onDelete: Cascade)
  data      Json
  createdAt DateTime    @default(now())
}

model ClientPortalUser {
  id           String   @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name         String
  email        String
  passwordHash String?
  createdAt    DateTime @default(now())
  @@unique([workspaceId, email])
}

// ─── INBOX / CONVERSATIONS ───────────────────────────────
model Conversation {
  id            String    @id @default(cuid())
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contactId     String?
  contact       Contact?  @relation(fields: [contactId], references: [id])
  channel       String    // "sms" | "email"
  subject       String?
  contactPhone  String?
  contactEmail  String?
  contactName   String?
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())

  messages ConversationMessage[]
}

model ConversationMessage {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  direction      String       // "outbound" | "inbound"
  body           String
  status         String       @default("sent") // "queued" | "sent" | "delivered" | "failed" | "received"
  externalId     String?
  createdAt      DateTime     @default(now())
}

// ─── CHART OF ACCOUNTS / GENERAL LEDGER ─────────────────
model ChartAccount {
  id          String      @id @default(cuid())
  workspaceId String
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  code        String      // e.g. "1000", "4100"
  name        String      // e.g. "Cash", "Service Revenue"
  type        AccountType // ASSET | LIABILITY | EQUITY | REVENUE | EXPENSE
  subtype     String?     // e.g. "Current Asset", "Operating Expense"
  description String?
  isSystem    Boolean     @default(false)
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())

  journalLines JournalLine[]

  @@unique([workspaceId, code])
}

model JournalEntry {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  date        DateTime
  memo        String?
  reference   String?
  sourceType  String?   // "invoice" | "expense" | "manual"
  sourceId    String?
  createdAt   DateTime  @default(now())

  lines JournalLine[]
}

model JournalLine {
  id             String       @id @default(cuid())
  journalEntryId String
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  accountId      String
  account        ChartAccount @relation(fields: [accountId], references: [id])
  debit          Float        @default(0)
  credit         Float        @default(0)
  memo           String?
}

// ─── EMAIL SEQUENCES (DRIP CAMPAIGNS) ────────────────────
model EmailSequence {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  description String?
  trigger     String   @default("manual") // manual | contact.created | tag.added | deal.stage_changed
  triggerValue String? // e.g. tag name or deal stage
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  steps       EmailSequenceStep[]
  enrollments SequenceEnrollment[]
}

model EmailSequenceStep {
  id         String        @id @default(cuid())
  sequenceId String
  sequence   EmailSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  stepNumber Int
  delayDays  Int           @default(0)  // days after previous step (or enrollment for step 1)
  subject    String
  body       String        // HTML/text body
  fromName   String?
  fromEmail  String?
  createdAt  DateTime      @default(now())
}

model SequenceEnrollment {
  id          String        @id @default(cuid())
  sequenceId  String
  sequence    EmailSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  workspaceId String
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contactId   String
  contact     Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)
  currentStep Int           @default(0)
  status      String        @default("ACTIVE") // ACTIVE | COMPLETED | PAUSED | UNSUBSCRIBED
  nextSendAt  DateTime?
  enrolledAt  DateTime      @default(now())
  completedAt DateTime?

  @@unique([sequenceId, contactId])
}

// ─── LANDING PAGES ───────────────────────────────────────
model LandingPage {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  slug        String
  published   Boolean   @default(false)
  blocks      Json      @default("[]")
  seoTitle    String?
  seoDesc     String?
  customCss   String?
  viewCount   Int       @default(0)
  leadCount   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([workspaceId, slug])
}

// ─── LIVE CHAT ───────────────────────────────────────────
model ChatWidget {
  id             String   @id @default(cuid())
  workspaceId    String   @unique
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  enabled        Boolean  @default(true)
  widgetColor    String   @default("#F59E0B")
  welcomeMessage String   @default("Hi! How can we help you today?")
  teamName       String   @default("Support")
  teamAvatar     String?
  aiEnabled      Boolean  @default(false)
  aiPrompt       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  conversations  ChatConversation[]
}

model ChatConversation {
  id            String     @id @default(cuid())
  widgetId      String
  widget        ChatWidget @relation(fields: [widgetId], references: [id], onDelete: Cascade)
  visitorId     String
  visitorName   String?
  visitorEmail  String?
  status        String     @default("OPEN")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  messages      ChatMessage[]

  @@index([widgetId])
  @@index([visitorId])
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String           // visitor | agent | ai
  content        String
  createdAt      DateTime         @default(now())

  @@index([conversationId])
}

// ─── PROPOSALS & E-SIGNATURES ────────────────────────────
model Proposal {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contactId   String?
  contact     Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  title       String
  status      String   @default("DRAFT") // DRAFT, SENT, VIEWED, SIGNED, DECLINED, EXPIRED
  content     Json     // Array of blocks: {type, data}
  total       Float    @default(0)
  validUntil  DateTime?
  publicToken String   @unique @default(cuid())
  signedAt    DateTime?
  signedBy    String?  // name entered on signature
  signatureData String? // base64 data URL or typed name
  declinedAt  DateTime?
  declineReason String?
  viewedAt    DateTime?
  sentAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── SOCIAL MEDIA ────────────────────────────────────────
model SocialPost {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  content     String
  platforms   String[] // "twitter","instagram","facebook","linkedin","tiktok"
  mediaUrls   String[]
  status      String   @default("DRAFT") // DRAFT | SCHEDULED | PUBLISHED | FAILED
  scheduledAt DateTime?
  publishedAt DateTime?
  errorMsg    String?
  twitterId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── PROJECT MANAGEMENT ──────────────────────────────────
model Project {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  description String?
  status      String   @default("ACTIVE") // ACTIVE | COMPLETED | ARCHIVED
  color       String   @default("#6366F1")
  contactId   String?
  contact     Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  dueDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tasks       Task[]
}

model Task {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workspaceId String
  title       String
  description String?
  status      String   @default("TODO") // TODO | IN_PROGRESS | REVIEW | DONE
  priority    String   @default("MEDIUM") // LOW | MEDIUM | HIGH | URGENT
  assigneeId  String?
  dueDate     DateTime?
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── INTEGRATIONS ─────────────────────────────────────────
model WorkspaceIntegration {
  id           String   @id @default(cuid())
  workspaceId  String
  provider     String   // 'quickbooks' | 'gohighlevel' | 'gmail' | 'smtp' | 'outlook' | 'xero'
  accessToken  String?  @db.Text
  refreshToken String?  @db.Text
  tokenExpiry  DateTime?
  apiKey       String?  @db.Text
  config       Json?    // provider-specific metadata: realmId, smtpHost, port, etc.
  status       String   @default("active") // 'active' | 'error' | 'expired'
  lastSyncAt   DateTime?
  syncCount    Int      @default(0)
  errorMsg     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, provider])
  @@index([workspaceId])
}

// ─── ENUMS ───────────────────────────────────────────────
enum MemberRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum Plan {
  FREE
  STARTER
  PRO
  AGENCY
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  VOID
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}
